{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/prelegal/legal-document-template.schema.json",
  "title": "Prelegal Legal Document Template",
  "type": "object",
  "required": [
    "id",
    "title",
    "category",
    "jurisdiction",
    "language",
    "description",
    "variables",
    "sections",
    "review_notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "jurisdiction": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "label", "type", "required"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "enum": ["string", "date", "number", "currency", "address", "email", "url", "choice"]
          },
          "required": {
            "type": "boolean"
          },
          "help_text": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "body"],
        "properties": {
          "heading": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "review_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
